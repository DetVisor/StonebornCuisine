    <building>
      <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
      <workTableRoomRole>Kitchen</workTableRoomRole>
      <workTableNotInRoomRoleFactor>0.5</workTableNotInRoomRoleFactor>
    </building>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
  </ThingDef>

  <!-- Stop snooping, you dog. -->

  <ThingDef ParentName="BuildingBase">
    <defName>SC_ArchotechMicrowave</defName>
    <label>quantum microgenerator</label>
    <description>A portable archotech machine that generates powerful radioactive microwaves, causing the molecules of matter stored inside to begin violently vibrating.</description>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>Things/Buildings/Production/Special/ArchotechMicrowave</texPath>
      <drawSize>1.2</drawSize>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <size>(1,1)</size>
    <minifiedDef>MinifiedThing</minifiedDef>
    <defaultPlacingRot>North</defaultPlacingRot>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.45</fillPercent>
    <pathCost>70</pathCost>
    <hasInteractionCell>True</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <thingCategories>
      <li>BuildingsSpecial</li>
    </thingCategories>
    <costList>
      <Steel>50</Steel>
      <ComponentSpacer>6</ComponentSpacer>
    </costList>
    <statBases>
      <MarketValue>2000</MarketValue>
      <MaxHitPoints>100</MaxHitPoints>
      <Flammability>0</Flammability>
      <Beauty>0</Beauty>
      <Mass>15</Mass>
      <WorkToBuild>2000</WorkToBuild>
    </statBases>
    <clearBuildingArea>false</clearBuildingArea>
    <thingSetMakerTags>
      <li>RewardStandardCore</li>
    </thingSetMakerTags>
    <building>
      <destroySound>BuildingDestroyed_Metal_Medium</destroySound>
      <isEdifice>false</isEdifice>
    </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>300</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Forbiddable"/>
      <li Class="PipeSystem.CompProperties_AdvancedResourceProcessor">
        <notWorkingKey>SC_MicrowaveNotWorking</notWorkingKey>
        <processes>
          <li>SC_Microwave_ReheatJellyGlazedShank</li>
          <li>SC_Microwave_ReheatRoastedMegascarab</li>
          <li>SC_Microwave_ReheatMushroomSoup</li>
          <li>SC_Microwave_ReheatRockdoughPizza</li>

          <li>SC_Microwave_HeatMetal</li>
        </processes>
        <progressBarOffset>(0,2,-0.4)</progressBarOffset>
        <alwaysShowProgressBar>false</alwaysShowProgressBar>
        <inProgressTexture>Things/Buildings/Production/Special/ArchotechMicrowaveFull</inProgressTexture>
        <finishedTexture>Things/Buildings/Production/Special/ArchotechMicrowaveFull</finishedTexture>
        <hideSettings>true</hideSettings>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>2</glowRadius>
        <glowColor>(214,221,60,0)</glowColor>
      </li>
    </comps>
    <inspectorTabs>
      <li>PipeSystem.ITab_Processor</li>
    </inspectorTabs>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <tickerType>Normal</tickerType>
    <rotatable>false</rotatable>
    <uiOrder>2790</uiOrder>
    <tradeTags>
      <li>ExoticBuilding</li>
    </tradeTags>
  </ThingDef>

</Defs>