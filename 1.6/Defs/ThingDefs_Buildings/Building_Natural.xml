<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <ThingDef ParentName="BuildingNaturalBase">
        <defName>SC_MoleroachNest</defName>
        <label>Moleroach burrow</label>
        <thingClass>Building</thingClass>
        <description>A small burrow dug out by a moleroach. Moleroach hens will try to lay their eggs in here if they can. Your haulers will take all the eggs out only when the box is full, to save time. The hole also protects eggs from deteriorating outdoors, though it does not protect from temperature damage.</description>
        <drawerType>MapMeshAndRealTime</drawerType>
        <fillPercent>0.3</fillPercent>
        <tickerType>Normal</tickerType>
        <drawGUIOverlay>true</drawGUIOverlay>
        <containedItemsSelectable>true</containedItemsSelectable>
        <graphicData>
            <texPath>Things/Buildings/Natural/MoleroachNest</texPath>
            <graphicClass>Graphic_Random</graphicClass>
            <damageData>
                <rect>(0,0,1,1)</rect>
            </damageData>
        </graphicData>
        <altitudeLayer>Building</altitudeLayer>
        <statBases>
            <MaxHitPoints>15</MaxHitPoints>
            <WorkToBuild>2000</WorkToBuild>
            <Flammability>1</Flammability>
            <Mass>3</Mass>
        </statBases>
        <comps>
            <li Class="CompProperties_ThingContainer">
                <compClass>CompEggContainer</compClass>
                <stackLimit>25</stackLimit>
                <minCountToEmpty>20</minCountToEmpty>
                <drawStackLabel>true</drawStackLabel>
            </li>
        </comps>
        <costList>
            <SC_DwarvenMilk>5</SC_DwarvenMilk>
        </costList>
        <pathCost>10</pathCost>
        <uiOrder>2060</uiOrder>
        <rotatable>false</rotatable>
        <building>
            <claimable>true</claimable>
            <deconstructible>true</deconstructible>
            <repairable>true</repairable>
            <paintable>false</paintable>
        </building>
    </ThingDef>

</Defs>