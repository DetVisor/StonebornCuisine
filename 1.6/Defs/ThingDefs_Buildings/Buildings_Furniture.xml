<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <ThingDef ParentName="ShelfBase">
        <defName>SC_FoodSpot</defName>
        <label>meal spot</label>
        <description>A spot designated for storing meals and foods, usually for large tables and feasts.</description>
        <graphicData>
            <texPath>Things/Buildings/Furniture/MealSpot</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(1,1)</drawSize>
        </graphicData>
        <researchPrerequisites>
            <li>SC_KitchenFurnishing</li>
        </researchPrerequisites>
        <thingCategories IsNull="True" />
        <rotatable>true</rotatable>
        <statBases Inherit="False">
            <WorkToBuild>0</WorkToBuild>
            <Flammability>0</Flammability>
        </statBases>
        <scatterableOnMapGen>false</scatterableOnMapGen>
        <useHitPoints>false</useHitPoints>
        <size>(1,1)</size>
        <uiIconScale>1</uiIconScale>
        <thingClass>Building_Storage</thingClass>
        <altitudeLayer>BuildingOnTop</altitudeLayer>
        <clearBuildingArea>false</clearBuildingArea>
        <stuffCategories Inherit="false" />
        <minifiedDef IsNull="True" />
        <building Inherit="False">
            <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
            <ignoreStoredThingsBeauty>false</ignoreStoredThingsBeauty>
            <blueprintClass>Blueprint_Storage</blueprintClass>
            <paintable>false</paintable>
            <isEdifice>false</isEdifice>
            <storageGroupTag>Shelf</storageGroupTag>
            <maxItemsInCell>1</maxItemsInCell>
            <fixedStorageSettings>
                <filter>
                    <disallowNotEverStorable>true</disallowNotEverStorable>
                    <categories>
                        <li>PlantFoodRaw</li>
                        <li>AnimalProductRaw</li>
                        <li>SC_FlourRaw</li>
                        <li>FoodMeals</li>
                        <li>Drugs</li>
                    </categories>
                    <thingDefs>
                        <li>SC_Feast_JellyGlazedShank</li>
                        <li>SC_Feast_RoastedMegascarab</li>
                        <li>SC_Feast_JellyGlazedShank</li>
                        <li>SC_Feast_RockdoughPizza</li>

                        <li>SC_Skewer_Meat</li>
                        <li>SC_Skewer_Vegetarian</li>

                        <li>SC_CheesePie</li>
                        <li>SC_ChocolatePie</li>
                        <li>SC_BerryPie</li>
                        <li>SC_Pastry</li>
                        <li>Chocolate</li>

                        <li>SC_MeatRockpie</li>
                        <li>SC_VeganRockpie</li>
                        <li>SC_MushroomRockpie</li>

                        <li>SC_CuredMeat</li>
                        <li>SC_InsectJerky</li>
                        <li MayRequire="Ludeon.RimWorld.Odyssey">SC_SaltedFish</li>
                        <li>SC_DriedHuman</li>

                        <li>SC_Burger_Caveburger</li>
                        <li>SC_Burger_Cheeseburger</li>
                        <li>SC_Burger_Veggieburger</li>

                        <li>SC_Skewer_Meat</li>
                        <li>SC_Skewer_Vegetarian</li>
                        <li>SC_Skewer_Fungus</li>
                        <li>SC_Skewer_Insect</li>
                    </thingDefs>
                    <disallowedThingDefs MayRequire="Ludeon.RimWorld.Biotech">
                        <li MayRequire="Ludeon.RimWorld.Biotech">Wastepack</li>
                    </disallowedThingDefs>
                    <specialFiltersToDisallow>
                        <li>AllowLargeCorpses</li>
                    </specialFiltersToDisallow>
                </filter>
            </fixedStorageSettings>
            <defaultStorageSettings>
                <priority>Preferred</priority>
                <filter>
                    <thingDefs>
                        <li>SC_Feast_JellyGlazedShank</li>
                        <li>SC_Feast_RoastedMegascarab</li>
                        <li>SC_Feast_JellyGlazedShank</li>
                        <li>SC_Feast_RockdoughPizza</li>

                        <li>SC_Skewer_Meat</li>
                        <li>SC_Skewer_Vegetarian</li>

                        <li>SC_CheesePie</li>
                        <li>SC_ChocolatePie</li>
                        <li>SC_BerryPie</li>
                        <li>SC_Pastry</li>
                        <li>Chocolate</li>

                        <li>SC_MeatRockpie</li>
                        <li>SC_VeganRockpie</li>
                        <li>SC_MushroomRockpie</li>

                        <li>SC_CuredMeat</li>
                        <li>SC_InsectJerky</li>
                        <li MayRequire="Ludeon.RimWorld.Odyssey">SC_SaltedFish</li>
                        <li>SC_DriedHuman</li>

                        <li>SC_Burger_Caveburger</li>
                        <li>SC_Burger_Cheeseburger</li>
                        <li>SC_Burger_Veggieburger</li>

                        <li>SC_Skewer_Meat</li>
                        <li>SC_Skewer_Vegetarian</li>
                        <li>SC_Skewer_Fungus</li>
                        <li>SC_Skewer_Insect</li>
                    </thingDefs>
                </filter>
            </defaultStorageSettings>
        </building>
    </ThingDef>

    <ThingDef ParentName="TableGatherSpotBase">
        <defName>SC_Table3x8c</defName>
        <label>table (3x8)</label>
        <graphicData>
            <texPath>Things/Buildings/Furniture/Table3x7</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(5,10)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
        </graphicData>
        <researchPrerequisites>
            <li>SC_KitchenFurnishing</li>
        </researchPrerequisites>
        <statBases>
            <MaxHitPoints>150</MaxHitPoints>
            <WorkToBuild>3000</WorkToBuild>
            <Mass>20</Mass>
            <Flammability>1.0</Flammability>
            <Beauty>2</Beauty>
            <StyleDominance MayRequire="Ludeon.RimWorld.Ideology">20</StyleDominance>
        </statBases>
        <size>(3,8)</size>
        <costStuffCount>125</costStuffCount>
        <building>
            <buildingSizeCategory>Medium</buildingSizeCategory>
        </building>
    </ThingDef>

