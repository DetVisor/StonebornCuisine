    <ThingDef ParentName="FurnitureWithQualityBase">
        <defName>SC_Bench1x3c</defName>
        <label>bench (1x3)</label>
        <description>A simple platform on which to sit. Not very comfortable, but much better than nothing. Can be used at tables, work stations, and elsewhere.</description>
        <replaceTags>
            <li>Chair</li>
        </replaceTags>
        <graphicData>
            <texPath>Things/Buildings/Furniture/Bench1x3</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(2.9,4.9)</drawSize>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
            <shadowData>
                <volume>(0.3, 0.23, 2.5)</volume>
            </shadowData>
        </graphicData>
        <researchPrerequisites>
            <li>SC_KitchenFurnishing</li>
        </researchPrerequisites>
        <altitudeLayer>Building</altitudeLayer>
        <statBases>
            <MaxHitPoints>75</MaxHitPoints>
            <WorkToBuild>450</WorkToBuild>
            <Mass>3</Mass>
            <Flammability>1.0</Flammability>
            <Beauty>0</Beauty>
            <Comfort>0.5</Comfort>
            <StyleDominance MayRequire="Ludeon.RimWorld.Ideology">5</StyleDominance>
        </statBases>
        <size>(1,3)</size>
        <socialPropernessMatters>true</socialPropernessMatters>
        <stuffCategories>
            <li>Metallic</li>
            <li>Woody</li>
            <li>Stony</li>
        </stuffCategories>
        <costStuffCount>25</costStuffCount>
        <pathCost>30</pathCost>
        <uiOrder>2400</uiOrder>
        <fillPercent>0.20</fillPercent>
        <building>
            <isSittable>true</isSittable>
            <multiSittable>true</multiSittable>
            <paintable>true</paintable>
        </building>
        <uiIconOffset>(0, -0.05)</uiIconOffset>
        <comps>
            <li Class="CompProperties_Styleable" />
        </comps>
    </ThingDef>

