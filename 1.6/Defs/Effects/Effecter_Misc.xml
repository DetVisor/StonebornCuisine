<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <EffecterDef>
    <defName>SC_EatBread</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
        <scale>0.4~0.7</scale>
        <ticksBetweenMotes>20</ticksBetweenMotes>
        <positionLerpFactor>0.35</positionLerpFactor>
        <moteDef>SC_Mote_FoodBitBread</moteDef>
      </li>
    </children>
  </EffecterDef>

  <ThingDef ParentName="FoodBitBase">
    <defName>SC_Mote_FoodBitBread</defName>
    <graphicData>
      <texPath>Things/Mote/FoodBitBread</texPath>
      <shaderType>Mote</shaderType>
    </graphicData>
  </ThingDef>

  <EffecterDef>
    <defName>SC_HotGrillEffect</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <moteDef>SC_Mote_HotGrillLogs</moteDef>
        <scale>2.6</scale>
        <rotation>0.1</rotation>
      </li>
    </children>
  </EffecterDef>

  <ThingDef ParentName="MoteBase">
    <defName>SC_Mote_HotGrillLogs</defName>
    <thingClass>MoteAttached</thingClass>
    <altitudeLayer>Terrain</altitudeLayer>
    <mote>
      <solidTime>9999</solidTime>
      <fadeInTime>0.1</fadeInTime>
      <fadeOutTime>0.1</fadeOutTime>
      <needsMaintenance>True</needsMaintenance>
      <fadeOutUnmaintained>True</fadeOutUnmaintained>
      <rotateTowardsTarget>True</rotateTowardsTarget>
      <rotateTowardsMoveDirection>True</rotateTowardsMoveDirection>
    </mote>
    <graphicData>
      <graphicClass>Graphic_Mote</graphicClass>
      <texPath>Things/Mote/HotGrillLogs</texPath>
      <drawSize>(5,3)</drawSize>
    </graphicData>
  </ThingDef>

  <EffecterDef>
    <defName>SC_FeastSteam</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerContinuous</subEffecterClass>
        <fleckDef>SC_SmokeGrowing</fleckDef>
        <scale>0.8~1.1</scale>
        <rotationRate>15~30</rotationRate>
        <speed>0.3~0.35</speed>
        <angle>32~40</angle>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
        <positionOffset>(0, 0, 0.5)</positionOffset>
        <positionRadius>0.2</positionRadius>
      </li>
      <li>
        <subEffecterClass>SubEffecter_DrifterEmoteChance</subEffecterClass>
        <scale>0.1~0.3</scale>
        <chancePerTick>0.001</chancePerTick>
        <positionRadius>0.5</positionRadius>
        <burstCount>2</burstCount>
        <moteDef>Mote_FeastSparkles</moteDef>
        <speed>0</speed>
        <rotation>0</rotation>
        <angle>0</angle>
      </li>
    </children>
  </EffecterDef>

  <FleckDef ParentName="FleckBase_Thrown">
    <defName>SC_SmokeGrowing</defName>
    <graphicData>
      <texPath>Things/Mote/Smoke</texPath>
      <renderInstanced>true</renderInstanced>
    </graphicData>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <fadeInTime>0.50</fadeInTime>
    <solidTime>1</solidTime>
    <fadeOutTime>1.5</fadeOutTime>
    <growthRate>0.3</growthRate>
  </FleckDef>

  <ThingDef ParentName="MoteBase">
    <defName>Mote_FeastSparkles</defName>
    <graphicData>
      <texPath>Things/Mote/FeastSparkles</texPath>
      <shaderType>MoteGlow</shaderType>
    </graphicData>
    <thingClass>MoteThrownAttached</thingClass>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <mote>
      <fadeInTime>0.30</fadeInTime>
      <solidTime>0.80</solidTime>
      <fadeOutTime>0.40</fadeOutTime>
      <attachedDrawOffset>(0, 0, 0.1)</attachedDrawOffset>
    </mote>
  </ThingDef>


  <ThingDef ParentName="MoteBase">
    <defName>SC_Mote_PotFlames</defName>
    <graphicData>
      <texPath>Things/Mote/PotFlame/PotFlame_Fleck</texPath>
      <shaderType>TransparentAnimated</shaderType>
      <shaderParameters>
        <_NumFrames>3</_NumFrames>
        <_FramesPerSec>4</_FramesPerSec>
      </shaderParameters>
      <graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
    </graphicData>
    <thingClass>MoteThrownAttached</thingClass>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <mote>
      <fadeInTime>0.4</fadeInTime>
      <solidTime>3.4</solidTime>
      <fadeOutTime>0.4</fadeOutTime>
      <attachedDrawOffset>(0, 0, 0.1)</attachedDrawOffset>
      <collide>true</collide>
    </mote>
  </ThingDef>

  <EffecterDef>
    <defName>SC_PotCooking</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <fleckDef>SmokeGrowing</fleckDef>
        <scale>1.1~1.5</scale>
        <rotationRate>15~30</rotationRate>
        <speed>0.3~0.35</speed>
        <angle>32~40</angle>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
        <positionOffset>(-0.05, 0.7, 1)</positionOffset>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <scale>1</scale>
        <spawnLocType>OnSource</spawnLocType>
        <chancePerTick>0.5</chancePerTick>
        <burstCount>1</burstCount>
        <moteDef>SC_Mote_PotFlames</moteDef>
        <speed>0</speed>
        <rotation>0</rotation>
        <angle>0</angle>
      </li>
    </children>
  </EffecterDef>

  <EffecterDef>
    <defName>SC_OvenSmoke</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
        <fleckDef>SmokeGrowing</fleckDef>
        <scale>1.1~1.5</scale>
        <rotationRate>15~30</rotationRate>
        <speed>0.3~0.35</speed>
        <angle>32~40</angle>
        <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
        <positionOffset>(-0.05, 0.7, 1)</positionOffset>
      </li>
    </children>
  </EffecterDef>

  <!--Artificial hive-->

  <ThingDef ParentName="MoteBase">
    <defName>SC_Mote_HiveFlyers</defName>
    <graphicData>
      <texPath>Things/Mote/ArtificialHive/SmallBugA</texPath>
      <shaderType>TransparentAnimated</shaderType>
      <shaderParameters>
        <_NumFrames>2</_NumFrames>
        <_FramesPerSec>10</_FramesPerSec>
      </shaderParameters>
      <graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
    </graphicData>
    <thingClass>MoteThrownAttached</thingClass>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <mote>
      <fadeInTime>0.34</fadeInTime>
      <solidTime>0.33</solidTime>
      <fadeOutTime>0.55</fadeOutTime>
      <attachedDrawOffset>(0, 0, 0.1)</attachedDrawOffset>
      <collide>true</collide>
    </mote>
  </ThingDef>

  <EffecterDef>
    <defName>SC_HiveFlyersEffect</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_DrifterEmoteChance</subEffecterClass>
        <scale>0.15~0.2</scale>
        <chancePerTick>0.02</chancePerTick>
        <positionRadius>0.7</positionRadius>
        <burstCount>1~1</burstCount>
        <moteDef>SC_Mote_HiveFlyers</moteDef>
        <speed>0.23</speed>
        <rotation>0.1</rotation>
      </li>
    </children>
  </EffecterDef>

</Defs>