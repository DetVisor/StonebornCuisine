<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="AnimalThingBase" Name="RockbullBase">
    <defName>SC_Rockbull</defName>
    <label>rockbull</label>
    <description>A stocky, naturally armored descendant of modern cows, selectively bred to be powerful and fierce. Rockbulls evolved to be able to eat anything, due to the scarce plant life in their cavern habitats, and are commonly found as part of stoneborn caravans or deepfarms.\n\nTheir four hefty horns make them a danger for apex predators as well as overconfident tamers: with their powerful legs, they can ram and stab anything they consider a threat.</description>
    <descriptionHyperlinks>
      <ThingDef>SC_DwarvenMilk</ThingDef>
    </descriptionHyperlinks>
    <statBases>
      <MoveSpeed>3.05</MoveSpeed>
      <ComfyTemperatureMin>-60</ComfyTemperatureMin>
      <ComfyTemperatureMax>35</ComfyTemperatureMax>
      <MarketValue>400</MarketValue>
      <ArmorRating_Sharp>0.60</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.32</ArmorRating_Blunt>
      <ArmorRating_Heat>0.22</ArmorRating_Heat>
      <FilthRate>20</FilthRate>
      <Wildness>0.35</Wildness>
    </statBases>
    <uiIconScale>1.15</uiIconScale>
    <comps>
      <li Class="CompProperties_Milkable">
        <milkDef>SC_DwarvenMilk</milkDef>
        <milkIntervalDays>4</milkIntervalDays>
        <milkAmount>25</milkAmount>
      </li>
      <li Class="VEF.AnimalBehaviours.CompProperties_LastStand">
        <finalCoolDownMultiplier>5</finalCoolDownMultiplier>
      </li>
      <li Class="VEF.AnimalBehaviours.CompProperties_DoesntFlee"></li>
    </comps>
    <race>
      <body>QuadrupedAnimalWithHooves</body>
      <herdAnimal>true</herdAnimal>
      <baseBodySize>2.3</baseBodySize>
      <baseHungerRate>0.6</baseHungerRate>
      <baseHealthScale>1.8</baseHealthScale>
      <foodType>OmnivoreRoughAnimal</foodType>
      <leatherDef>SC_Rockhide</leatherDef>
      <roamMtbDays>4</roamMtbDays>
      <petness>0.23</petness>
      <trainability>None</trainability>
      <packAnimal>true</packAnimal>
      <meatLabel>rockbull beef</meatLabel>
      <gestationPeriodDays>8</gestationPeriodDays>
      <lifeExpectancy>50</lifeExpectancy>
      <manhunterOnDamageChance>0.2</manhunterOnDamageChance>
      <wildBiomes>
        <TemperateForest>0.76</TemperateForest>
        <TemperateSwamp>0.52</TemperateSwamp>
        <BorealForest>0.8</BorealForest>
        <Tundra>0.6</Tundra>
      </wildBiomes>
      <lifeStageAges>
        <li>
          <def>AnimalBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>AnimalJuvenile</def>
          <minAge>0.2</minAge>
        </li>
        <li>
          <def>AnimalAdult</def>
          <minAge>0.3333</minAge>
          <soundWounded>Pawn_Bison_Wounded</soundWounded>
          <soundDeath>Pawn_Bison_Death</soundDeath>
          <soundCall>Pawn_Bison_Call</soundCall>
          <soundAngry>Pawn_Bison_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_BigBash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_BigBash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_BigBash_Miss</soundMeleeMiss>
      <headPosPerRotation>
        <li>(0.0, 0, 0.27)</li>
        <li>(0.3, 0, 0.015)</li>
        <li>(0.0, 0, -0.19)</li>
        <li>(-0.3, 0, 0.015)</li>
      </headPosPerRotation>
    </race>
    <tradeTags>
      <li>AnimalStoneborn</li>
      <li>AnimalFarm</li>
    </tradeTags>
    <tools>
      <li>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>8.2</power>
        <cooldownTime>3</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <chanceFactor>0.7</chanceFactor>
      </li>
      <li>
        <label>horns</label>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>9.6</power>
        <cooldownTime>3.2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.8</chanceFactor>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>14</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>left hoof</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>8</power>
        <cooldownTime>2.4</cooldownTime>
        <linkedBodyPartsGroup>FrontLeftLeg</linkedBodyPartsGroup>
      </li>
      <li>
        <label>right hoof</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>8</power>
        <cooldownTime>2.4</cooldownTime>
        <linkedBodyPartsGroup>FrontRightLeg</linkedBodyPartsGroup>
      </li>
    </tools>
  </ThingDef>

