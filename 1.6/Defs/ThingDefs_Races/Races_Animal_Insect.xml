<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef Abstract="True" ParentName="AnimalThingBase" Name="BaseThermalite">
    <devNote>insect</devNote>
    <statBases>
      <ToxicResistance>1</ToxicResistance>
      <ComfyTemperatureMax>60</ComfyTemperatureMax>
      <ToxicEnvironmentResistance MayRequire="Ludeon.RimWorld.Biotech">0.8</ToxicEnvironmentResistance>
    </statBases>
    <race>
      <fleshType>Insectoid</fleshType>
      <bloodDef>Filth_BloodInsect</bloodDef>
      <meatColor>(160,168,139)</meatColor>
      <meatMarketValue>0.5</meatMarketValue>
      <foodType>OmnivoreAnimal, AnimalProduct</foodType>
      <manhunterOnDamageChance>0.50</manhunterOnDamageChance>
      <soundEating>Insectoid_Eat</soundEating>
    </race>
    <ingredient>
      <mergeCompatibilityTags>
        <li MayRequire="Ludeon.RimWorld.Ideology">InsectMeat</li>
      </mergeCompatibilityTags>
    </ingredient>
    <receivesSignals>true</receivesSignals>
  </ThingDef>

  <!-- ====================================================== -->

  <ThingDef ParentName="BaseThermalite" Name="BaseMoleroach">
    <defName>SC_Insect_Moleroach</defName>
    <label>moleroach</label>
    <description>A medium-sized, non-eusocial bioengineered insectoid the size of a lamb. They're often utilized by stoneborn for their value as both meat providers and egg layers, as their eggs are large and nutrient-rich, and moleroach hens lay them often enough to sustain colonies. Moleroaches will also build burrows to lay their eggs in.</description>
    <statBases>
      <MoveSpeed>4</MoveSpeed>
      <ComfyTemperatureMin>-25</ComfyTemperatureMin>
      <MarketValue>200</MarketValue>
      <LeatherAmount>0</LeatherAmount>
      <ArmorRating_Blunt>0.22</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.12</ArmorRating_Sharp>
      <Wildness>0</Wildness>
    </statBases>
    <uiIconScale>1.1</uiIconScale>
    <comps>
      <li Class="CompProperties_EggLayer">
        <eggUnfertilizedDef>SC_MoleroachEggUnfertilized</eggUnfertilizedDef>
        <eggFertilizedDef>SC_MoleroachEggFertilized</eggFertilizedDef>
        <eggFertilizationCountMax>1</eggFertilizationCountMax>
        <eggLayIntervalDays>2.2</eggLayIntervalDays>
        <eggCountRange>2~3</eggCountRange>
      </li>
      <li Class="VEF.AnimalBehaviours.CompProperties_BuildPeriodically">
        <defOfBuilding>SC_MoleroachNest</defOfBuilding>
        <ticksToBuild>3200</ticksToBuild>
        <onlyOneExistingPerPawn>true</onlyOneExistingPerPawn>
        <maxBuildingsPerMap>100</maxBuildingsPerMap>
        <onlyTamed>true</onlyTamed>
        <checkForExistingEdifices>true</checkForExistingEdifices>
      </li>
    </comps>
    <tools>
      <li>
        <label>mandibles</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>7</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadClaw</linkedBodyPartsGroup>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <thinkTreeMain>SC_CustomAnimal</thinkTreeMain>
      <body>BeetleLikeWithClaw</body>
      <baseHungerRate>0.25</baseHungerRate>
      <baseBodySize>0.8</baseBodySize>
      <baseHealthScale>1.7</baseHealthScale>
      <foodType>VegetarianRoughAnimal, OmnivoreAnimal</foodType>
      <useMeatFrom>Megaspider</useMeatFrom>
      <roamMtbDays>3</roamMtbDays>
      <mateMtbHours>8</mateMtbHours>
      <lifeExpectancy>4</lifeExpectancy>
      <trainability>Advanced</trainability>
      <wildBiomes>
        <LavaField MayRequire="Ludeon.RimWorld.Odyssey">0.8</LavaField>
        <Scarlands MayRequire="Ludeon.RimWorld.Odyssey">0.7</Scarlands>
        <AridShrubland>0.666</AridShrubland>
        <Desert>0.52</Desert>
        <ExtremeDesert>0.44</ExtremeDesert>
        <TemperateForest>0.43</TemperateForest>
        <TemperateSwamp>0.43</TemperateSwamp>
      </wildBiomes>
      <specialTrainables>
        <li MayRequire="Ludeon.RimWorld.Odyssey">Dig</li>
      </specialTrainables>
      <lifeStageAges>
        <li>
          <def>SC_InsectLarva</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>SC_InsectJuvenile</def>
          <minAge>0.03</minAge>
        </li>
        <li>
          <def>SC_InsectAdult</def>
          <minAge>0.2</minAge>
          <soundWounded>Pawn_Spelopede_Pain</soundWounded>
          <soundDeath>Pawn_Spelopede_Death</soundDeath>
          <soundCall>Pawn_Spelopede_Call</soundCall>
          <soundAngry>Pawn_Spelopede_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      <headPosPerRotation>
        <li>(0.0, 0, 0.14)</li>
        <li>(0.07, 0, 0.08)</li>
        <li>(0.0, 0, -0.12)</li>
        <li>(-0.07, 0, 0.08)</li>
      </headPosPerRotation>
    </race>
    <tradeTags>
      <li>AnimalFarm</li>
      <li>AnimalInsect</li>
      <li>AnimalStoneborn</li>
    </tradeTags>
  </ThingDef>

