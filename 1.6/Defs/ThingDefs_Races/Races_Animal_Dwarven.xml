<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="AnimalThingBase">
    <defName>SC_Creamgrub</defName>
    <label>creamgrub</label>
    <description>A bioengineered grub the size of a sheep. These eusocial insects were originally the larval stage of a giant moth species native to Grugni, but they were selectively bred and tweaked to skip any metamorphosis. Creamgrubs still produce silk, which can be harvested. Their bodies are also composed of "dwarven milk", and will yield it upon slaughter.</description>
    <statBases>
      <MoveSpeed>1.5</MoveSpeed>
      <ComfyTemperatureMin>-30</ComfyTemperatureMin>
      <MarketValue>450</MarketValue>
      <LeatherAmount>0</LeatherAmount>
      <ArmorRating_Blunt>0.30</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.05</ArmorRating_Sharp>
      <Wildness>0.3</Wildness>
      <ToxicResistance>1</ToxicResistance>
      <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1</VacuumResistance>
      <ComfyTemperatureMax>60</ComfyTemperatureMax>
      <ToxicEnvironmentResistance>0.8</ToxicEnvironmentResistance>
    </statBases>
    <killedLeavingsRanges>
      <SC_DwarvenMilk>65~75</SC_DwarvenMilk>
    </killedLeavingsRanges>
    <ingredient>
      <mergeCompatibilityTags>
        <li MayRequire="Ludeon.RimWorld.Ideology">InsectMeat</li>
      </mergeCompatibilityTags>
    </ingredient>
    <uiIconScale>1.1</uiIconScale>
    <comps>
      <li Class="CompProperties_EggLayer">
        <eggUnfertilizedDef>SC_EggCreamgrubUnfertilized</eggUnfertilizedDef>
        <eggFertilizedDef>SC_EggCreamgrubFertilized</eggFertilizedDef>
        <eggFertilizationCountMax>1</eggFertilizationCountMax>
        <eggLayIntervalDays>1.33</eggLayIntervalDays>
        <eggProgressUnfertilizedMax>0.5</eggProgressUnfertilizedMax>
        <eggCountRange>1~2</eggCountRange>
      </li>
      <li Class="VEF.AnimalBehaviours.CompProperties_AnimalProduct">
        <resourceDef>SC_Creamsilk</resourceDef>
        <gatheringIntervalDays>8</gatheringIntervalDays>
        <resourceAmount>40</resourceAmount>
        <customResourceString>SC_CreamgrubResourceString</customResourceString>
        <isRandom>false</isRandom>
      </li>
    </comps>
    <tools>
      <li>
        <label>mandibles</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>4</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadClaw</linkedBodyPartsGroup>
      </li>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>5</power>
        <cooldownTime>2</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
    </tools>
    <race>
      <deathAction Class="DeathActionProperties_Vanish">
        <workerClass>DeathActionWorker_Vanish</workerClass>
        <filth>SC_Filth_Milk</filth>
        <filthCountRange>2~3</filthCountRange>
        <meatExplosionSize>Small</meatExplosionSize>
      </deathAction>
      <thinkTreeMain>Animal</thinkTreeMain>
      <intelligence>Animal</intelligence>
      <roamMtbDays>7</roamMtbDays>
      <mateMtbHours>8</mateMtbHours>
      <petness>0.50</petness>
      <herdAnimal>true</herdAnimal>
      <fleshType>Insectoid</fleshType>
      <bloodDef>SC_Filth_Milk</bloodDef>
      <meatMarketValue>0.5</meatMarketValue>
      <manhunterOnDamageChance>0.50</manhunterOnDamageChance>
      <soundEating>Insectoid_Eat</soundEating>
      <canBeVacuumBurnt>true</canBeVacuumBurnt>
      <body>BeetleLikeWithClaw</body>
      <baseHungerRate>0.33</baseHungerRate>
      <baseBodySize>0.9</baseBodySize>
      <baseHealthScale>1.4</baseHealthScale>
      <specificMeatDef>SC_DwarvenMilk</specificMeatDef>
      <lifeExpectancy>6</lifeExpectancy>
      <trainability>None</trainability>
      <foodType>OmnivoreRoughAnimal</foodType>
      <wildBiomes>
        <TropicalSwamp>0.72</TropicalSwamp>
        <TropicalSwamp>0.67</TropicalSwamp>
        <TropicalRainforest>0.43</TropicalRainforest>
        <AridShrubland>0.55</AridShrubland>
        <TemperateForest>0.43</TemperateForest>
        <TemperateSwamp>0.43</TemperateSwamp>
      </wildBiomes>
      <lifeStageAges>
        <li>
          <def>SC_InsectLarva</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>SC_InsectJuvenile</def>
          <minAge>0.03</minAge>
        </li>
        <li>
          <def>SC_InsectAdult</def>
          <minAge>0.2</minAge>
          <soundWounded>Pawn_Spelopede_Pain</soundWounded>
          <soundDeath>Pawn_Spelopede_Death</soundDeath>
          <soundCall>Pawn_Spelopede_Call</soundCall>
          <soundAngry>Pawn_Spelopede_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      <headPosPerRotation>
        <li>(0.0, 0, 0.14)</li>
        <li>(0.07, 0, 0.08)</li>
        <li>(0.0, 0, -0.12)</li>
        <li>(-0.07, 0, 0.08)</li>
      </headPosPerRotation>
    </race>
    <tradeTags>
      <li>AnimalInsect</li>
    </tradeTags>
  </ThingDef>

