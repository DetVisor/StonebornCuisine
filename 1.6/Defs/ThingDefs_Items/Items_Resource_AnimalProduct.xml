<?xml version="1.0" encoding="utf-8" ?>
<Defs>


  <ThingDef ParentName="OrganicProductBase">
    <defName>SC_DwarvenMilk</defName>
    <label>cave milk</label>
    <description>Milk from a cave animal, of stoneborn origin.</description>
    <graphicData>
      <texPath>Things/Item/Resource/DwarvenMilk</texPath>
      <drawSize>1.1</drawSize>
    </graphicData>
    <socialPropernessMatters>true</socialPropernessMatters>
    <statBases>
      <MarketValue>3</MarketValue>      <!-- Can be used like meat in recipes -->
      <Mass>0.045</Mass>
      <MaxHitPoints>60</MaxHitPoints>
      <Flammability>0.1</Flammability>
      <Nutrition>0.07</Nutrition>
      <FoodPoisonChanceFixedHuman>0.05</FoodPoisonChanceFixedHuman>
    </statBases>
    <comps>
      <li Class="CompProperties_Rottable">
        <daysToRotStart>24</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <ingestible>
      <preferability>RawTasty</preferability>
      <foodType>AnimalProduct, Fluid</foodType>
      <babiesCanIngest>true</babiesCanIngest>
    </ingestible>
    <thingCategories>
      <li>AnimalProductRaw</li>
    </thingCategories>
    <allowedArchonexusCount>80</allowedArchonexusCount>
  </ThingDef>

  <ThingDef ParentName="EggUnfertBase">
    <defName>SC_EggCreamgrubUnfertilized</defName>
    <label>creamgrub egg (unfert.)</label>
    <description>An unfertilized chicken egg. It can be eaten raw, but it's much, much better cooked.</description>
    <graphicData>
      <texPath>Things/Item/Resource/CreamgrubEgg</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>7.0</MarketValue>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="EggFertBase">
    <defName>SC_EggCreamgrubFertilized</defName>
    <label>creamgrub egg (fert.)</label>
    <description>A fertilized chicken egg. If all goes well, it should hatch into a chick. It can be eaten raw, but it's much better cooked.</description>
    <possessionCount>1</possessionCount>
    <graphicData>
      <texPath>Things/Item/Resource/CreamgrubEgg</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>7.0</MarketValue>
    </statBases>
    <comps>
      <li Class="CompProperties_Hatcher">
        <hatcherDaystoHatch>3.5</hatcherDaystoHatch>
        <hatcherPawn>SC_Creamgrub</hatcherPawn>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="EggUnfertBase">
    <defName>SC_MoleroachEggUnfertilized</defName>
    <label>moleroach egg (unfert.)</label>
    <description>An unfertilized moleroach egg. It can be eaten raw, but it's much, much better cooked.</description>
    <graphicData>
      <texPath>Things/Item/Resource/MoleroachEggUnfert</texPath>
      <drawSize>0.8</drawSize>
      <color>(255,255,255)</color>
    </graphicData>
    <statBases>
      <Nutrition>0.35</Nutrition>
      <FoodPoisonChanceFixedHuman>0.01</FoodPoisonChanceFixedHuman>
    </statBases>
    <statBases>
      <MarketValue>7.0</MarketValue>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="EggFertBase">
    <defName>SC_MoleroachEggFertilized</defName>
    <label>moleroach egg (fert.)</label>
    <description>A moleroach egg. If all goes well, it should hatch into a nymph. It can be eaten raw, but it's much better cooked.</description>
    <possessionCount>1</possessionCount>
    <graphicData>
      <texPath>Things/Item/Resource/MoleroachEggFert</texPath>
      <drawSize>0.8</drawSize>
    </graphicData>
    <statBases>
      <Nutrition>0.35</Nutrition>
      <FoodPoisonChanceFixedHuman>0.01</FoodPoisonChanceFixedHuman>
    </statBases>
    <statBases>
      <MarketValue>7.0</MarketValue>
    </statBases>
    <comps>
      <li Class="CompProperties_Hatcher">
        <hatcherDaystoHatch>3.5</hatcherDaystoHatch>
        <hatcherPawn>SC_Moleroach</hatcherPawn>
      </li>
    </comps>
  </ThingDef>

</Defs>