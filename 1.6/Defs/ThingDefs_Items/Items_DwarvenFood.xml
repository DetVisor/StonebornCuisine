      <MarketValue>8</MarketValue>
      <Mass>0.20</Mass>
      <Flammability>0.3</Flammability>
      <WorkToMake>900</WorkToMake>
      <DeteriorationRate>1.2</DeteriorationRate>
      <Nutrition>1.2</Nutrition>
    </statBases>
    <ingestible>
      <preferability>MealFine</preferability>
      <tasteThought>SC_Thought_AteRockburger</tasteThought>
      <ingestSound>Meal_Eat</ingestSound>
      <optimalityOffsetHumanlikes>9</optimalityOffsetHumanlikes>
      <maxNumToIngestAtOnce>2</maxNumToIngestAtOnce>
      <defaultNumToIngestAtOnce>1</defaultNumToIngestAtOnce>
    </ingestible>
    <comps>
      <li Class="CompProperties_Rottable">
