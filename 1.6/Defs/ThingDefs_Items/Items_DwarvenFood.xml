<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!--Rockbread-->

  <ThingDef ParentName="OrganicProductBase">
    <defName>SC_Rockbread</defName>
    <label>rockbread</label>
    <description>Extremely hard and crunchy bread, baked with as few ingredients as possible. It can resist for years on end, and the heft makes it a viable blunt weapon as well.</description>
    <thingClass>ThingWithComps</thingClass>
    <techLevel>Neolithic</techLevel>
    <thingCategories>
      <li>Foods</li>
    </thingCategories>
    <graphicData>
      <texPath>Things/Item/Resource/RockBread</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <socialPropernessMatters>true</socialPropernessMatters>
    <statBases>
      <MarketValue>4</MarketValue>
      <Mass>0.20</Mass>
      <Flammability>0</Flammability>
      <WorkToMake>1200</WorkToMake>
      <DeteriorationRate>0.8</DeteriorationRate>
      <Nutrition>0.10</Nutrition>
    </statBases>
    <ingestible>
      <foodType>Meal</foodType>
      <preferability>MealSimple</preferability>
      <ingestEffect>SC_EatBread</ingestEffect>
      <ingestSound>Meal_Eat</ingestSound>
      <optimalityOffsetHumanlikes>9</optimalityOffsetHumanlikes>
    </ingestible>
    <equipmentType>Primary</equipmentType>
    <comps>
      <li Class="CompProperties_Rottable">
        <daysToRotStart>120</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
      <li Class="CompProperties_Ingredients">
        <noIngredientsFoodKind>NonMeat</noIngredientsFoodKind>
      </li>
      <li Class="CompProperties_FoodPoisonable" />
      <li>
        <compClass>CompEquippable</compClass>
      </li>
    </comps>
    <weaponClasses>
      <li>Melee</li>
      <li>MeleeBlunt</li>
    </weaponClasses>
    <tools>
      <li>
        <label>loaf</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    <allowedArchonexusCount>200</allowedArchonexusCount>
  </ThingDef>

