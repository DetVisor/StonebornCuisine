<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ProcessorFramework.ProcessDef>
    <defName>SC_CureMeat</defName>
    <thingDef>SC_CuredMeat</thingDef>
    <ingredientFilter>
      <categories>
        <li>MeatRaw</li>
      </categories>
      <disallowedCategories>
        <li>Fish</li>
      </disallowedCategories>
      <disallowedThingDefs>
        <li>Meat_Human</li>
        <li>Meat_Megaspider</li>
        <li>SC_CuredMeat</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Meat_Twisted</li>
      </disallowedThingDefs>
    </ingredientFilter>
    <processDays>10</processDays>    <!-- in days, a day is 60,000 ticks -->
    <capacityFactor>0.5</capacityFactor>
    <efficiency>0.5</efficiency>
    <usesTemperature>true</usesTemperature>
    <temperatureSafe>10~20</temperatureSafe>
    <temperatureIdeal>14~16</temperatureIdeal>
    <ruinedPerDegreePerHour>2.5</ruinedPerDegreePerHour>    <!-- percent per degree per hour -->
    <speedBelowSafe>0.4</speedBelowSafe>
    <speedAboveSafe>1.0</speedAboveSafe>
    <sunFactor>1.0~1.0</sunFactor>
    <rainFactor>1.0~1.0</rainFactor>
    <snowFactor>1.0~1.0</snowFactor>
    <windFactor>1.0~1.0</windFactor>
    <unfueledFactor>1.0</unfueledFactor>
    <fuelUseFactor>1.0</fuelUseFactor>
    <filledGraphicSuffix>_fullMeat</filledGraphicSuffix>
    <usesQuality>false</usesQuality>
    <customLabel>Cured</customLabel>
    <destroyChance>0.0</destroyChance>
  </ProcessorFramework.ProcessDef>

