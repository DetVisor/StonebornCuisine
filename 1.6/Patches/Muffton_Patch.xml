<?xml version="1.0" encoding="utf-8" ?>
<Patch>


    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Dark Ages : Beasts and Monsters</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[defName = "DA_DwarvenMuffton"]/comps</xpath>
                    <value>
                        <comps>
                            <li Class="CompProperties_Milkable">
                                <milkDef>SC_DwarvenMilk</milkDef>
                                <milkIntervalDays>1</milkIntervalDays>
                                <milkAmount>10</milkAmount>
                            </li>

                            <li Class="CompProperties_Shearable">
                                <woolDef>DA_WoolMuffton</woolDef>
                                <shearIntervalDays>15</shearIntervalDays>
                                <woolAmount>30</woolAmount>
                            </li>
                        </comps>
                    </value>
                </li>
            </operations>
        </match>
    </Operation>
</Patch>